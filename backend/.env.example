# query-mind Environment Variables
# Copy this file to .env and fill in your values

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# App Configuration
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-app.com

# Direct app database connection used by SQLAlchemy repositories and Alembic.
# For Supabase, use the direct Postgres connection string, not the REST API URL.
APP_DATABASE_URL=postgresql+psycopg2://postgres:password@db.your-project-id.supabase.co:5432/postgres

# Optional local/demo database used only for BACKEND_DEV_MODE seeding of a connected analytics DB.
DATABASE_URL=postgresql://user:password@localhost:5432/query_mind_demo

# Redis / Celery Configuration
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_DEFAULT_QUEUE=default
CELERY_SCHEDULED_QUEUE=scheduled
CELERY_TEMPLATES_QUEUE=templates
CELERY_DISPATCH_LOCK_SECONDS=900
CELERY_WORKER_CONCURRENCY=4

# Database Connection Guardrails
DB_CONNECT_TIMEOUT_SECONDS=5
DB_CONNECT_RATE_LIMIT_ATTEMPTS=10
DB_CONNECT_RATE_LIMIT_WINDOW_SECONDS=60
DB_CONNECT_ALLOWED_HOSTS=
DB_CONNECT_ALLOWED_CIDRS=
DB_CONNECT_ALLOW_PRIVATE_IN_DEV=true

# Database Credential Encryption (MANDATORY FOR PROD)
# Generate a Fernet key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REQUIRED_FOR_PRODUCTION_SECURITY

# Supabase Auth Configuration
# Go to Supabase Project Settings -> API / JWT Settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=REQUIRED_FOR_SECURE_AUTH_VERIFICATION

# Lemon Squeezy (Payments)
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here
LEMON_SQUEEZY_API_KEY=your_api_key_here

# Mode Configuration
BACKEND_DEV_MODE=false
DEV_USER_ID=00000000-0000-0000-0000-000000000000
DEV_USER_EMAIL=dev@query-mind.com
